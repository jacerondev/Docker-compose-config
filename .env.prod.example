# filepath: .env.prod.example
# ══════════════════════════════════════════════════════════════════════════════
# .env.prod.example — Plantilla para PRODUCCIÓN
# ⚠️ NUNCA ejecutar: docker compose -f ... up directamente en producción
# SIEMPRE usar: make prod (valida TAG, secretos y configuración antes)
#
# USO:
#   En el servidor: cp .env.prod.example .env.production
#   Luego editar:   nano .env.production
#   Permisos:       chmod 600 .env.production
#
# REGLAS:
#   ✅ Este archivo SÍ se versiona (es solo plantilla, sin valores reales)
#   ❌ .env.production NO se versiona (.gitignore lo excluye)
#
# IMPORTANTE — Separación de responsabilidades:
#   .env.production  → Variables NO sensibles (URLs, puertos, nombres, entornos)
#   secrets/         → Credenciales sensibles (contraseñas, tokens)
#
#   Las contraseñas NO van aquí. Van en Docker Secrets:
#     make secrets-init      ← crea secrets/db_password.txt etc.
#     make secrets-check     ← verifica que estén configurados
#   La app lee los secretos desde /run/secrets/<nombre> dentro del contenedor.
#
# Ver ENV-VARIABLES.md para documentación detallada de cada variable.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos (conexión, NO credenciales) ─────────────────────────────────
# host-gateway: Docker 20.10+ resuelve a la IP del host automáticamente.
# Necesario porque los contenedores usan red 'internal: true' y PostgreSQL
# está en el host (no en Docker). Ver DECISIONS.md ADR-007.
DB_HOST=host-gateway
DB_PORT=5432
DB_NAME=nombre_del_proyecto_prod
# NO pongas DB_USER ni DB_PASSWORD aquí en producción.
# Usa Docker Secrets: make secrets-init
# La app los lee desde:
#   /run/secrets/db_user      → referenciado por DB_USER_FILE=/run/secrets/db_user
#   /run/secrets/db_password  → referenciado por DB_PASSWORD_FILE=/run/secrets/db_password

# --- CONFIGURACIÓN DE MONITOREO (si usas docker-compose.monitoring.yml) ---
# Credenciales para acceder a las métricas protegidas por autenticación básica
# Generar con: openssl rand -base64 24
METRICS_USER=prometheus
# METRICS_PASSWORD viene de Docker Secret en producción:
# make secrets-init → crea secrets/metrics_password.txt

# ── Puertos internos de los contenedores ────────────────────────────────────
PORT_BACKEND=4000
PORT_FRONTEND=3000
PORT_REPORTS=5000

# --- VERSIONES DE HERRAMIENTAS (opcional, para build de imágenes) ---
PNPM_VERSION=10.32.1

# ── URLs públicas (baked en el bundle de Next.js durante build) ──────────────
# IMPORTANTE: Cambiar estas URLs requiere rebuild completo de la imagen frontend.
# Ver DECISIONS.md ADR-002.
NEXT_PUBLIC_API_URL=https://api.tudominio.com
NEXT_PUBLIC_REPORTS_URL=https://reports.tudominio.com

# ── CORS ────────────────────────────────────────────────────────────────────
# Dominios permitidos para hacer requests al backend y reports
# Separados por coma, sin espacios, con esquema (https://)
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# Dominios permitidos para cargar recursos (Content-Security-Policy via Helmet)
# Dominios desde donde tu API acepta o sirve contenido incrustado.
HELMET_ALLOWED_DOMAINS=https://tudominio.com,https://www.tudominio.com

# Deshabilitar Swagger en producción (no recomendado exponerlo públicamente)
# Credenciales para Swagger UI (solo aplican con: make dev-swagger)
SWAGGER_ENABLED=false

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=production
# FLASK_DEBUG debe ser 0 en producción — el reloader/debugger no se usa con Gunicorn
FLASK_DEBUG=0

# ── Imágenes (opcional: para apuntar a un registry privado) ─────────────────
# Si no se definen, docker-compose.prod.yml usa nombre_del_proyecto/service:latest
# Ejemplo con GitHub Container Registry:
# IMAGE_BACKEND=ghcr.io/tu-org/nombre_del_proyecto/backend:2026.02.24
# IMAGE_FRONTEND=ghcr.io/tu-org/nombre_del_proyecto/frontend:2026.02.24
# IMAGE_REPORTS=ghcr.io/tu-org/nombre_del_proyecto/reports:2026.02.24

# ── Monitoreo (solo si usas docker-compose.monitoring.yml) ──────────────────
# Stack opcional: Prometheus + Grafana + Node Exporter + cAdvisor
# Levanta con: make monitoring-up
# PREREQUISITO: echo "tu_password" > secrets/grafana_password.txt
#
# Nota: En producción, estos puertos solo son accesibles desde 127.0.0.1
# Para acceder, usar SSH tunnel: ssh -L 3001:127.0.0.1:3001 usuario@servidor
#
PORT_PROMETHEUS=9090
PORT_GRAFANA=3001
# PORT_NODE_EXPORTER=9100   # No expuesto directamente, Prometheus lo scrapea
# PORT_CADVISOR=8080         # No expuesto directamente, Prometheus lo scrapea
# ── Autenticación JWT ────────────────────────────────────────────────────────
# IMPORTANTE: JWT_SECRET en producción debe ir en Docker Secrets, NO aquí.
# Crear: echo "$(openssl rand -base64 48)" > secrets/jwt_secret.txt
# Referencia en docker-compose.prod.yml como JWT_SECRET_FILE=/run/secrets/jwt_secret

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- AUTENTICACIÓN ---
#
# AUTH_MODE — controla el modo del JwtAuthGuard en el backend NestJS.
#
# En producción DEBE ser 'real'. El servidor FALLA al arrancar si
# NODE_ENV=production y AUTH_MODE no es 'real'.
# Ver: backend/src/auth/guards/jwt-auth.guard.ts y DECISIONS.md ADR-022.
AUTH_MODE=real

# NESTJS_AUTH_TIMEOUT — Tiempo máximo para esperar respuesta del backend (segundos).
# Suficiente para una red Docker interna en el mismo host.
NESTJS_AUTH_TIMEOUT=1.0

# --- SSL (si usas certificados SSL) ---
# PostgreSQL está en el mismo host (como indica ADR-006),
# el tráfico no sale de la máquina y SSL no es estrictamente necesario.
# Sin embargo, si en el futuro la DB se mueve a un servicio externo,
# esta variable DB_SSL_REQUIRED debe ser true.
DB_SSL_REQUIRED=false   # Aceptable mientras la BD esté en el mismo host
# NOTA: Cambiar a true y configurar DB_SSL_CA si BD se mueve a host externo
# DB_SSL_CA=--- RUTA_AL_CERTIFICADO_CA ---  # Solo si DB_SSL_REQUIRED=true

# --- REDIS OBLIGATORIO EN PRODUCCIÓN ---
REDIS_URL=redis://nombre_del_proyecto_redis:6379/0
# La contraseña viene de: secrets/redis_secret.txt (generado con make secrets-init)
# NO definir REDIS_PASSWORD aquí — se lee desde Docker Secret en el código
# filepath: .gitignore

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
lib-cov
coverage
*.lcov
.nyc_output

# Build tools
.grunt
bower_components
.lock-wscript
build/Release

# Dependency directories
node_modules/
jspm_packages/
web_modules/

# TypeScript cache
*.tsbuildinfo

# npm/yarn/etc caches
.npm
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.node_repl_history
*.tgz
.yarn-integrity

# dotenv — archivos de entorno con valores reales (NUNCA al repo)
.env
.env.production
.env.prod
.env.local

# Docker Secrets — NUNCA versionar credenciales
secrets/
secrets/*.txt
secrets/*.key
secrets/*.pem

# Evidencia de auditoría local (logs generados por make audit-full)
# Estos archivos son output local, no van al repo.
# CORRECCIÓN: el directorio es scripts/tests/ (con 's' final)
scripts/tests/*.log
scripts/tests/pip-audit.log
scripts/tests/grype-*.log
scripts/tests/trivy-*.log
# Los SBOMs JSON sí pueden versionarse como evidencia.
# Si prefieres no versionarlos, descomenta:
# scripts/tests/sbom-*.json

# Next.js
.next
out

# Nuxt.js
.nuxt
dist

# Gatsby / Vuepress / Docusaurus
.cache/
.docusaurus
.vuepress/dist
.temp

# Serverless / FuseBox / DynamoDB Local
.serverless/
.fusebox/
.dynamodb/

# VSCode testing
.vscode-test

# Parcel
.parcel-cache

# Yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Slack
monitoring/prometheus.yml
monitoring/alertmanager.yml
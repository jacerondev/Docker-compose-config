# filepath: .env.example
# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Plantilla de variables de entorno para DESARROLLO
#
# USO:
#   make setup         ← copia este archivo a .env automáticamente
#   cp .env.example .env && nano .env  ← o copiar manualmente
#
# REGLAS:
#   ✅ Este archivo SÍ se versiona (es solo plantilla)
#   ❌ .env NO se versiona (.gitignore lo excluye)
#
# IMPORTANTE:
#   Este archivo es SOLO para desarrollo local.
#   Para producción → usa .env.prod.example → .env.production
#
# Los valores aquí son válidos para desarrollo y para CI.
# En CI: cp .env.example .env  ← debe funcionar sin editar nada.
#
# Ver ENV-VARIABLES.md para documentación detallada de cada variable.
# ══════════════════════════════════════════════════════════════════════════════

# --- CONFIGURACIÓN DE BASE DE DATOS ---
# En desarrollo las credenciales van aquí (no hay Docker Secrets en dev)
DB_USER=user_dev
# Considerar usar una contraseña generada aleatoriamente incluso en desarrollo, para evitar malos hábitos.
DB_PASSWORD=password_dev
DB_READ_ONLY_USER=user_dev_readonly
# Considerar usar una contraseña generada aleatoriamente incluso en desarrollo, para evitar malos hábitos.
DB_READ_ONLY_PASSWORD=password_dev_readonly
DB_NAME=nombre_del_proyecto_db
# DB_HOST — hostname de PostgreSQL.
#
# ¿Por qué hay dos valores posibles?
#   Los contenedores Docker no pueden usar 'localhost' para llegar al host
#   porque dentro del contenedor 'localhost' es el propio contenedor.
#   Necesitan la IP del host vista desde la red Docker.
#
# VALOR EN ESTE ARCHIVO (desarrollo con docker-compose.override.yml):
#   DB_HOST=postgres
#   → El contenedor 'postgres' está en la misma red Docker (definido en override.yml)
#   → Docker DNS resuelve 'postgres' a la IP del contenedor de base de datos
#   → Funciona en CI y en cualquier máquina con `make dev`
#
# VALOR ALTERNATIVO (si PostgreSQL está en el host, no en Docker):
#   DB_HOST=host-gateway    ← Docker 20.10+ — resuelve automáticamente a la IP del host
#   DB_HOST=172.17.0.1      ← IP fija del bridge Docker en Linux (si host-gateway no funciona)
#   DB_HOST=host.docker.internal  ← Solo en macOS / Docker Desktop
#
# EN PRODUCCIÓN (.env.production):
#   DB_HOST=host-gateway    ← PostgreSQL corre en el host (sin Docker), ver ADR-006
#
# RESUMEN:
#   make dev (con contenedor postgres)  → DB_HOST=postgres
#   PostgreSQL en el host               → DB_HOST=host-gateway
DB_HOST=postgres
DB_PORT=5432

# --- PUERTOS DE SERVICIOS (INTERNOS, COINCIDEN CON DOCKER-COMPOSE.OVERRIDE) ---
PORT_BACKEND=4000
PORT_FRONTEND=3000
PORT_REPORTS=5000

# --- PUERTOS DE DEBUGGEO
PORT_DEBUG_BACKEND=9229

# --- VERSIONES DE HERRAMIENTAS (opcional, para build de imágenes) ---
PNPM_VERSION=10.32.1

# --- CONFIGURACIÓN PARA EL FRONTEND (NEXT.JS) ---
# Esta URL la usa el NAVEGADOR DEL CLIENTE para contactar al backend
# En desarrollo: localhost (el navegador accede directamente)
# En producción: https://api.tudominio.com (se define en .env.production)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Esta URL la usa el NAVEGADOR DEL CLIENTE para contactar al servicio de reports
NEXT_PUBLIC_REPORTS_URL=http://localhost:5000

# --- CONFIGURACIÓN PARA EL BACKEND (NESTJS) ---
NODE_ENV=development

# --- CONFIGURACIÓN PARA REPORTS (PYTHON) ---
APP_ENV=development
# FLASK_DEBUG: flag nativo de Flask para el reloader/debugger (1=activo | 0=inactivo)
# Independiente de FLASK_ENV — solo relevante con 'flask run', no con Gunicorn
FLASK_DEBUG=1

# AUTH_MODE — guard JWT del backend: 'development' (temporal) | 'real' (JWT verificado)
# ⚠️  El servidor NestJS no arranca si NODE_ENV=production y AUTH_MODE≠real
AUTH_MODE=development

# URL INTERNA de Docker: reports-api llama a backend por la red interna de Docker
# Usa el nombre del servicio 'backend' (definido en docker-compose.yml)
# No usar 'localhost' aquí — localhost dentro del contenedor es el propio contenedor
NESTJS_AUTH_URL=http://backend:4000

# NESTJS_AUTH_TIMEOUT — Tiempo máximo para esperar respuesta del backend (segundos).
# Suficiente para una red Docker interna en el mismo host.
NESTJS_AUTH_TIMEOUT=1.0

# --- CORS ---
# Orígenes permitidos para CORS (separados por coma, sin espacios)
ALLOWED_ORIGINS=http://localhost:3000

# Dominios permitidos para cargar recursos (Content-Security-Policy via Helmet)
# En desarrollo suele ser 'self' o los dominios locales.
HELMET_ALLOWED_DOMAINS=http://localhost:3000

# --- CONFIGURACIÓN DE MONITOREO (si usas docker-compose.monitoring.yml) ---
# Credenciales para acceder a las métricas protegidas por autenticación básica
# Generar con: openssl rand -base64 24
METRICS_USER=prometheus
METRICS_PASSWORD=CAMBIAR_genera_con_openssl_rand_base64_24

# Deshabilitar Swagger en producción (no recomendado exponerlo públicamente)
# Credenciales para Swagger UI (solo aplican con: make dev-swagger)
SWAGGER_USER=dev
SWAGGER_PASSWORD=CAMBIAR_genera_con_openssl_rand_base64_12

# --- REGLAS JWT ---
#
# JWT_SECRET — Clave secreta para firmar los tokens JWT.
#
# ¿Por qué importa?
#   Si esta clave se compromete, cualquiera puede generar tokens válidos
#   y acceder a la aplicación como cualquier usuario.
#
# En desarrollo (este archivo):
#   El valor placeholder es intencionalmente inválido para forzarte a cambiarlo.
#   El backend FALLARÁ al arrancar si JWT_SECRET no está definido (cuando
#   AuthModule esté habilitado). Para desarrollo, cualquier string largo sirve.
#
# Cómo generar un valor seguro:
#   openssl rand -base64 48
#   → Te da algo como: "kP3mQ+9xLzR1nT7vW0sA2bC4dE6fG8hI..." (64 chars)
#
# En CI (este .env.example se copia tal cual):
#   El valor placeholder funciona en CI porque AuthModule aún no está activo.
#   Cuando se active auth, CI debe inyectar JWT_SECRET como GitHub Secret.
#
# En producción:
#   NO va en .env.production — va en Docker Secrets:
#   echo "$(openssl rand -base64 48)" > secrets/jwt_secret.txt
#   Ver .env.prod.example para instrucciones completas.
# El setup.sh también detecta el placeholder y lo reemplaza automáticamente en desarrollo, para mayor seguridad. Ver scripts/setup.sh.
JWT_SECRET=CAMBIAR_genera_con_openssl_rand_base64_48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CONFIGURACIÓN DE HASHING DE CONTRASEÑAS ---
# PEPPER_SECRET — Valor secreto adicional para el hashing de contraseñas (argon2)
PEPPER_SECRET=CAMBIAR_genera_con_openssl_rand_base64_32

# --- CONFIGURACIÓN DE COOKIES ---
# COOKIE_SECRET — Clave secreta para firmar cookies httpOnly (usada por cookie
COOKIE_SECRET=CAMBIAR_genera_con_openssl_rand_hex_48

# --- IMÁGENES (opcional) ---
# Solo se usan si quieres apuntar a un registry privado en desarrollo.
# Si no se definen, docker-compose.yml hace build local automáticamente.
# IMAGE_BACKEND=nombre_del_proyecto/backend:2026.02.20
# IMAGE_FRONTEND=nombre_del_proyecto/frontend:2026.02.20
# IMAGE_REPORTS=nombre_del_proyecto/reports:2026.02.20

# --- MONITOREO (solo si usas docker-compose.monitoring.yml) ---
# Puertos del stack de Prometheus + Grafana
# Si cambias PORT_GRAFANA, también actualiza GF_SERVER_ROOT_URL en docker-compose.monitoring.yml
# PORT_PROMETHEUS=9090
# PORT_GRAFANA=3001
# PORT_NODE_EXPORTER=9100
# PORT_CADVISOR=8080

# Alertmanager — solo para producción (ver docs/guides/MONITORING-ALERTMANAGER.md)
# Crear en: https://api.slack.com/apps → Incoming Webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- SSL (si usas certificados SSL) ---
DB_SSL_REQUIRED=false
# DB_SSL_CA=--- RUTA_AL_CERTIFICADO_CA ---  # Solo si DB_SSL_REQUIRED=true

# --- REDIS (opcional — si no está definido, se usa memory:// en su lugar) ---
# Activar con: make dev-with-redis
# Redis (opcional — si no está definido, se usa memory:// en su lugar)
# Activar con: make dev-with-redis
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=CAMBIAR_genera_con_openssl_rand_hex_32